rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════
    //  دوال مساعدة
    // ══════════════════════════════════════════════════════
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════════
    //  بيانات المستخدم: الملف الشخصي + الإعدادات
    // ══════════════════════════════════════════════════════
    match /users/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);

      // مشاريع المستخدم — يملكها هو فقط
      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }

      // طلبات عروض الأسعار التي أرسلها المستخدم
      match /quote_requests/{quoteId} {
        allow read, write: if isOwner(uid);
      }

      // الطلبات الواردة للمورّد — يقرأها ويكتب عليها هو فقط
      match /incoming_quotes/{quoteId} {
        allow read:  if isOwner(uid);
        // المورّد يقرأ ويحدّث، والمستخدم يكتب عند الإرسال
        allow write: if isAuth();
      }
    }

    // ══════════════════════════════════════════════════════
    //  قراءة الموردين — أي مستخدم مسجّل يمكنه الاطلاع
    // ══════════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if isAuth()
        && resource.data.userType == 'supplier';
    }
  }
}
